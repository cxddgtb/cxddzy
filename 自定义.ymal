  Github: { type: http, behavior: classical, interval: 86400, url: "https://fastly.jsdelivr.net/gh/blackmatrix7/ios_rule_script@master/rule/Clash/GitHub/GitHub.yaml", path: ./rule/Github.yaml }
  Microsoft: { type: http, behavior: classical, interval: 86400, url: "https://fastly.jsdelivr.net/gh/blackmatrix7/ios_rule_script@master/rule/Clash/Microsoft/Microsoft.yaml", path: ./rule/Microsoft.yaml }
  Google: { type: http, behavior: classical, interval: 86400, url: "https://fastly.jsdelivr.net/gh/blackmatrix7/ios_rule_script@master/rule/Clash/Google/Google.yaml", path: ./rule/Google.yaml }
